{
  "name": "pfads-plus",
  "version": "1.0.0",
  "description": "PFADS+ mental health and academic dropout prevention prototype",
  "main": "backend/server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:ai\"",
    "dev:api": "nodemon backend/server.js",
    "dev:ai": "python ai/service.py",
    "start": "node backend/server.js",
    "lint": "node --check backend/server.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.12.1",
    "morgan": "^1.10.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9"
  }
}
